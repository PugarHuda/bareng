# Copy to .env.local and fill in. All NEXT_PUBLIC_ vars are exposed to the browser.

# Particle dashboard → https://dashboard.particle.network
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Magic dashboard → https://dashboard.magic.link (publishable key)
NEXT_PUBLIC_MAGIC_KEY=

# ZeroDev dashboard → https://dashboard.zerodev.app (bundler/paymaster RPC)
# Enables on-chain enforcement of the per-member 7702 spend cap (lib/zerodev.ts).
NEXT_PUBLIC_ZERODEV_RPC=
